struct VSOutput {
    float4 pos : SV_POSITION;
    float4 color; 
    float2 uv;
    float shape_mode;
    float op0;
    float op1;
}

struct Vertex
{
    float2 pos : POSITION;
    float4 color : COLOR;
    float2 uv : TEXCOORD0;
    float shape_mode;
    float op0;
    float op1;
}

struct Camera
{
    float4x4 proj;
}

ConstantBuffer<Camera> camera;



[shader("vertex")]
VSOutput vertexMain(Vertex vertex) {
    VSOutput output;
    output.pos = mul(camera.proj, float4(vertex.pos, 0, 1.0));
    output.color = vertex.color;
    output.uv = vertex.uv;
    output.shape_mode = vertex.shape_mode;
    output.op0 = vertex.op0;
    output.op1 = vertex.op1;
    

    return output;
}

struct FSOutput {
    float4 color0SW : SV_Target0;
}

Texture2D input_textures[32];
SamplerState input_samplers[32];

float median(float r, float g, float b) {
    return max(min(r, g), min(max(r, g), b));
}





[shader("fragment")]
FSOutput fragmentMain(VSOutput vsOutput) {


    FSOutput output;
    if(vsOutput.shape_mode >= 0) {
        Texture2D texture = input_textures[int(vsOutput.op0)];
        SamplerState sampler = input_samplers[int(vsOutput.op0)];



        if(int(vsOutput.op0) == 1) {
            float w, h, num_levels;
            texture.GetDimensions(0, w, h, num_levels);
            w = 1 / w;
            h = 1 / h;

            float4 color_samples = texture.Sample(sampler, vsOutput.uv) * vsOutput.color;

            {
                int pcf_kernel_w = 2, pcf_kernel_h = 2;

                for (int x = -pcf_kernel_w; x <= pcf_kernel_w; x++) {
                    for (int y = -pcf_kernel_h; y <= -pcf_kernel_h; y++) {
                        float4 sample = texture.Sample(sampler, vsOutput.uv + float2(2 * x, 2 * y) * float2(w, h));

                        color_samples.rgb += sample.rgb;
                    }
                }





            }


            output.color0SW = color_samples;


        }
        else {
            output.color0SW = texture.Sample(sampler, vsOutput.uv) * vsOutput.color;
        }



    }
    else if (vsOutput.shape_mode == -1) output.color0SW = vsOutput.color;
    else if (vsOutput.shape_mode == -2) {
        float2 uv = vsOutput.uv * 2.0 - 1.0;
        float distance = length(uv);

        if(distance <= 1.0 && distance >= (1.0 - 0.5)) output.color0SW = vsOutput.color;
        else discard;
    }
    else if (vsOutput.shape_mode == -3) {
        float3 msd = input_textures[int(vsOutput.op0)] .Sample(input_samplers[int(vsOutput.op0)], vsOutput.uv) .xyz;
        float sd = median(msd.r, msd.g, msd.b);
        float screenPxDistance = vsOutput.op1 * (sd - 0.5);
        float opacity = clamp(screenPxDistance + 0.5, 0.0, 1.0);

        output.color0SW = lerp(0.0, vsOutput.color, opacity);
    }



    return output;
}